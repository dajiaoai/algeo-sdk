  "devDependencies": {
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-replace": "^6.0.1",
    "@rollup/plugin-typescript": "^11.1.6",
    "rollup": "^4.28.1",
    "tslib": "^2.8.0",
    "typescript": "^5.9.3"
